cc_library_shared {
    name: "sensors.asteroids",
    defaults: ["hidl_defaults"],
    init_rc: ["sensors.asteroids.rc"],
    required: ["asteroids_hals.conf"],
    srcs: [
        "Sensor.cpp",
        "SensorsSubHal.cpp",
    ],
    shared_libs: [
        "android.hardware.sensors@1.0",
        "android.hardware.sensors@2.0",
        "android.hardware.sensors@2.0-ScopedWakelock",
        "android.hardware.sensors@2.1",
        "libcutils",
        "libfmq",
        "libhardware",
        "libhidlbase",
        "liblog",
        "libpower",
        "libutils",
    ],
    static_libs: [
        "android.hardware.sensors@1.0-convert",
        "android.hardware.sensors@2.X-multihal",
    ],
    cflags: [
        "-DLOG_TAG=\"sensors.asteroids\"",
    ],
    device_specific: true,
}

prebuilt_etc {
    name: "asteroids_hals.conf",
    filename: "hals.conf",
    src: "hals.conf",
    sub_dir: "sensors",
    device_specific: true,
}
